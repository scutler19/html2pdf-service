# Copy to ".env.local" (gitignored). docker-compose.local.yml loads this file when present.
# Root `.env` is not passed into the local web container, so Render keys stay out unless you
# put them here. DATABASE_URL is set by compose to the local Postgres service — do not set
# it here for the Docker workflow.

# For /api/convert without seeding accounts: comma-separated keys (trimmed). Optional.
# VALID_API_KEYS=my-local-dev-key

# Optional — set to true to accept the literal demo key (see README); never enable in prod unless intended.
# ALLOW_DEMO_KEY=true

# Optional — real test keys from the Stripe dashboard if you need subscribe/billing/webhooks
STRIPE_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET_TEST=whsec_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me_live_if_needed
